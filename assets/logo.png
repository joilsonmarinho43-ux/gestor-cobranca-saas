from PIL import Image

with st.sidebar:

    logo_path = os.path.join(BASE_DIR, "assets", "logo.png")

    if os.path.exists(logo_path):
        try:
            img = Image.open(logo_path)
            st.image(img, width=150)
        except Exception:
            st.title("☀️ Sol da Vida")
    else:
        st.title("☀️ Sol da Vida")

    st.markdown("---")

    menu = st.radio(
        "Menu",
        [
            "Dashboard",
            "Clientes",
            "Financeiro",
            "WhatsApp",
            "Relatórios"
        ]
    )
